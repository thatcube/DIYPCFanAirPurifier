rule C_COMPILER____idf_ieee802154_unscanned_
  depfile = $DEP_FILE
  deps = gcc
  command = ${LAUNCHER}${CODE_CHECK}/Users/brandon/.platformio/packages/toolchain-riscv32-esp/bin/riscv32-esp-elf-gcc $DEFINES $INCLUDES $FLAGS -MD -MT $out -MF $DEP_FILE -o $out -c $in
  description = Building C object $out


#############################################
# Rule for linking C static library.

rule C_STATIC_LIBRARY_LINKER____idf_ieee802154_
  command = $PRE_LINK && /Users/brandon/.platformio/packages/tool-cmake/bin/cmake -E rm -f $TARGET_FILE && /Users/brandon/.platformio/packages/toolchain-riscv32-esp/bin/riscv32-esp-elf-ar qc $TARGET_FILE $LINK_FLAGS $in && /Users/brandon/.platformio/packages/toolchain-riscv32-esp/bin/riscv32-esp-elf-ranlib $TARGET_FILE && /Users/brandon/.platformio/packages/tool-cmake/bin/cmake -E touch $TARGET_FILE && $POST_BUILD
